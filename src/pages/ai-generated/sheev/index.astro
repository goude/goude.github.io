---
import Layout from "@/layouts/Layout.astro";
import CodeBlock from "@/components/CodeBlock.astro";
import screenshot from "./_files/goattracker2.webp?url";
import buildScript from "./_files/build_goattracker2_macos.sh?raw";
---

<Layout
  title="GoatTracker2 on macOS"
  description="Building GoatTracker2 on modern macOS with SDL12-compat."
>
  <article>
    <header>
      <h1>GoatTracker2 on macOS</h1>

      <aside
        class="provenance-note"
        role="note"
        aria-label="Authorship and provenance note"
      >
        <span class="provenance-label">AI-generated text</span>
        <span class="provenance-text"
          >Drafted with an AI system. Reviewed and edited by a human.</span
        >
      </aside>
    </header>

    <p>
      <strong>GoatTracker2</strong> is a SID tracker for the Commodore 64. It compiles
      cleanly on modern macOS with
      <code>sdl12-compat</code> once you fix the include paths and avoid GNU strip
      assumptions.
    </p>

    <img
      src={screenshot}
      alt="GoatTracker2 running on macOS"
      loading="lazy"
      decoding="async"
    />

    <h2>Build script</h2>
    <CodeBlock code={buildScript} lang="bash" />

    <footer>
      <nav aria-label="Related pages">
        <p class="text-muted">See also:</p>
        <ul>
          <li>
            <a href="/ai-generated/beat-learn">Beat Practice Ladder</a> — building
            rhythm skills on Digitakt
          </li>
          <li>
            <a href="/ai-generated/patch-learn">Sound Design Practice Ladder</a> —
            building patch skills on Novation Peak
          </li>
        </ul>
      </nav>
    </footer>
  </article>
</Layout>
