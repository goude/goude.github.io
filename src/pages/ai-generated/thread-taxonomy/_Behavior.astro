<!-- ===================== BEHAVIOR ===================== -->
<section id="cat-behavior" aria-labelledby="cat-behavior-heading">
  <h2 id="cat-behavior-heading">Behavior</h2>
  <p>
    Interaction patterns that reduce clarity or accountability without
    necessarily being malicious.
  </p>

  <!-- 4/5 -->
  <section id="vague" data-term="vague" aria-labelledby="vague-heading">
    <h3 id="vague-heading">Vague</h3>
    <p>Non-actionable phrasing.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Translate to concrete proposal.</dd>
      <dt>Prevention</dt>
      <dd>Encourage problem + proposal norm.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="4" min="0" max="5" title="4/5">4 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. "Do you mean X?"</dd>
      <dt>If next step fails</dt>
      <dd>Offer two specific interpretations.</dd>
    </dl>
  </section>

  <!-- 3/5 -->
  <section id="driveby" data-term="driveby" aria-labelledby="driveby-heading">
    <h3 id="driveby-heading">Driveby</h3>
    <p>Comment without ownership.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Ask who will take it.</dd>
      <dt>Prevention</dt>
      <dd>Pair comments with owners.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="3" min="0" max="5" title="3/5">3 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Curious tone.</dd>
      <dt>If next step fails</dt>
      <dd>Assign provisional owner.</dd>
    </dl>
  </section>
</section>
