<!-- ===================== OWNERSHIP ===================== -->
<section id="cat-ownership" aria-labelledby="cat-ownership-heading">
  <h2 id="cat-ownership-heading">Ownership</h2>
  <p>
    Patterns where responsibility is unclear, diffused, or improperly
    transferred.
  </p>

  <!-- 5/5 -->
  <section
    id="ownerless"
    data-term="ownerless"
    aria-labelledby="ownerless-heading"
  >
    <h3 id="ownerless-heading">Ownerless</h3>
    <p>No clear responsible individual.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Propose specific DRI.</dd>
      <dt>Prevention</dt>
      <dd>Default to single owner per task.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="5" min="0" max="5" title="5/5">5 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. "Suggest X owns unless objections."</dd>
      <dt>If next step fails</dt>
      <dd>Volunteer temporarily and request formal owner.</dd>
    </dl>
  </section>

  <!-- 4/5 -->
  <section
    id="diffused"
    data-term="diffused"
    aria-labelledby="diffused-heading"
  >
    <h3 id="diffused-heading">Diffused</h3>
    <p>Too many recipients, no actor.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Narrow to 1–2 named individuals.</dd>
      <dt>Prevention</dt>
      <dd>Avoid broad CC unless informational.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="4" min="0" max="5" title="4/5">4 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Tag specific names.</dd>
      <dt>If next step fails</dt>
      <dd>Restart smaller thread.</dd>
    </dl>
  </section>

  <!-- 3/5 -->
  <section
    id="delegated"
    data-term="delegated"
    aria-labelledby="delegated-heading"
  >
    <h3 id="delegated-heading">Delegated</h3>
    <p>Task handed off but not accepted.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Request explicit confirmation.</dd>
      <dt>Prevention</dt>
      <dd>Normalize acknowledgment on delegation.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="3" min="0" max="5" title="3/5">3 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Direct but neutral.</dd>
      <dt>If next step fails</dt>
      <dd>Escalate or reassign.</dd>
    </dl>
  </section>

  <!-- 3/5 -->
  <section
    id="stranded"
    data-term="stranded"
    aria-labelledby="stranded-heading"
  >
    <h3 id="stranded-heading">Stranded</h3>
    <p>Blocked by absent decision authority.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Frame crisp decision question.</dd>
      <dt>Prevention</dt>
      <dd>Clarify decision rights early.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="3" min="0" max="5" title="3/5">3 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Options-based framing.</dd>
      <dt>If next step fails</dt>
      <dd>Escalate with summary + impact.</dd>
    </dl>
  </section>
</section>
