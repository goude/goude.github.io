<!-- ===================== SIGNAL ===================== -->
<section id="cat-signal" aria-labelledby="cat-signal-heading">
  <h2 id="cat-signal-heading">Signal</h2>
  <p>
    Structural problems in clarity, focus, and information flow within a thread.
  </p>

  <!-- 4/5 -->
  <section id="buried" data-term="buried" aria-labelledby="buried-heading">
    <h3 id="buried-heading">Buried</h3>
    <p>Key issue lost in long thread.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Extract to new focused thread.</dd>
      <dt>Prevention</dt>
      <dd>Single-topic discipline.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="4" min="0" max="5" title="4/5">4 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Announce new thread for clarity.</dd>
      <dt>If next step fails</dt>
      <dd>Close old thread explicitly.</dd>
    </dl>
  </section>

  <!-- 4/5 -->
  <section
    id="underspecified"
    data-term="underspecified"
    aria-labelledby="underspecified-heading"
  >
    <h3 id="underspecified-heading">Underspecified</h3>
    <p>Missing details block action.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Request minimal checklist info.</dd>
      <dt>Prevention</dt>
      <dd>Use structured templates.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="4" min="0" max="5" title="4/5">4 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Neutral, factual gaps.</dd>
      <dt>If next step fails</dt>
      <dd>Propose assumptions and proceed unless corrected.</dd>
    </dl>
  </section>

  <!-- 3/5 -->
  <section
    id="fragmented"
    data-term="fragmented"
    aria-labelledby="fragmented-heading"
  >
    <h3 id="fragmented-heading">Fragmented</h3>
    <p>Context split across tools or threads.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Consolidate and link canonical source.</dd>
      <dt>Prevention</dt>
      <dd>Maintain single source of truth.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="3" min="0" max="5" title="3/5">3 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Reference summary doc.</dd>
      <dt>If next step fails</dt>
      <dd>Create short recap and anchor future discussion.</dd>
    </dl>
  </section>

  <!-- 3/5 -->
  <section
    id="hijacked"
    data-term="hijacked"
    aria-labelledby="hijacked-heading"
  >
    <h3 id="hijacked-heading">Hijacked</h3>
    <p>Thread drifts away from original topic.</p>
    <dl>
      <dt>Next step</dt>
      <dd>Suggest splitting topic.</dd>
      <dt>Prevention</dt>
      <dd>Subject-line discipline.</dd>
      <dt>Commonality</dt>
      <dd>
        <meter value="3" min="0" max="5" title="3/5">3 out of 5</meter>
      </dd>
      <dt>Channel</dt>
      <dd>Public. Polite redirect.</dd>
      <dt>If next step fails</dt>
      <dd>Hard split into new thread.</dd>
    </dl>
  </section>
</section>
