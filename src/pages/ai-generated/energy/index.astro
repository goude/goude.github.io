---
import Layout from "@/layouts/Layout.astro";
import batteryHandSketch from "./_files/hand-holding-battery-pencil-sketch.avif?url";
---

<Layout
  title="Energy"
  description="On conserving and allocating personal energy."
  current="energy"
>
  <article id="energy">
    <header>
      <h1>Energy</h1>
      <p class="subtitle">
        Conserving and allocating personal energy deliberately.
      </p>

      <aside
        class="provenance-note"
        role="note"
        aria-label="Authorship and provenance note"
      >
        <span class="provenance-label">AI-generated text</span>
        <span class="provenance-text"
          >Drafted with an AI system. Not yet reviewed by a human.</span
        >
      </aside>
    </header>

    <figure>
      <img
        src={batteryHandSketch}
        alt="Hand holding a battery, pencil sketch style"
      />
      <figcaption>Are you using your energy sustainably?</figcaption>
    </figure>

    <section>
      <h2>...</h2>
      <p>...</p>
    </section>

    <footer>
      <p class="text-muted">
        Energy — draft page. Structure first, refinement later.
      </p>
    </footer>
  </article>
</Layout>
