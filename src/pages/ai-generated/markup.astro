---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Markup Test"
  description="Comprehensive HTML rendering test page"
  current="markup"
>
  <article id="markup-test">
    <header>
      <h1>Markup Test</h1>
      <p class="subtitle">Rendering reference for semantic HTML elements.</p>

      <aside
        class="provenance-note"
        role="note"
        aria-label="Authorship and provenance note"
      >
        <span class="provenance-label">AI-generated text</span>
        <span class="provenance-text"
          >Drafted with an AI system. Reviewed and edited by a human.</span
        >
      </aside>

      <nav aria-label="Markup sections">
        <ul>
          <li><a href="#text">Text</a></li>
          <li><a href="#lists">Lists</a></li>
          <li><a href="#tables">Tables</a></li>
          <li><a href="#media">Media</a></li>
          <li><a href="#forms">Forms</a></li>
          <li><a href="#interactive">Interactive</a></li>
          <li><a href="#misc">Misc</a></li>
        </ul>
      </nav>
    </header>

    <!-- TEXT -->

    <section id="text">
      <h2>Text & Inline Semantics</h2>

      <p>
        <strong>strong</strong>, <em>em</em>, <b>b</b>, <i>i</i>,
        <u>u</u>, <mark>mark</mark>, <small>small</small>,
        <sub>sub</sub>, <sup>sup</sup>, <s>strikethrough</s>.
      </p>

      <p>
        <abbr title="HyperText Markup Language">HTML</abbr>,
        <cite>citation</cite>, <q>inline quote</q>,
        <bdi>مرحبا</bdi>, soft<wbr />break.
      </p>

      <p>
        Inline code <code>const x = 42;</code>,
        <kbd><kbd>Ctrl</kbd> + <kbd>C</kbd></kbd>,
        <samp>output</samp>,
        <var>variable</var>.
      </p>

      <pre><code>function greet(name: string): string &#123;
  return `Hello, $&#123;name&#125;!`;
&#125;</code></pre>

      <p>
        <ins>Inserted</ins> and <del>deleted</del> text.
      </p>

      <ruby>
        漢 <rt>kan</rt>
      </ruby>

      <blockquote>
        <p>
          Blockquote example with enough text to show how longer quotations wrap
          and display within the left-bordered container.
        </p>
        <footer>— Author</footer>
      </blockquote>

      <hr />

      <address>
        <a href="mailto:test@example.com">test@example.com</a>
      </address>
    </section>

    <!-- LISTS -->

    <section id="lists">
      <h2>Lists</h2>

      <ul>
        <li>Unordered</li>
        <li>
          Nested
          <ul>
            <li>Level 2</li>
          </ul>
        </li>
      </ul>

      <ol>
        <li>Ordered</li>
        <li>Second</li>
      </ol>

      <dl>
        <dt>Term</dt>
        <dd>Definition</dd>
      </dl>
    </section>

    <!-- TABLES -->

    <section id="tables">
      <h2>Tables</h2>

      <table>
        <caption>Table Example</caption>
        <thead>
          <tr>
            <th scope="col">A</th>
            <th scope="col">B</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Row 1</th>
            <td>Data</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2">Footer</td>
          </tr>
        </tfoot>
      </table>
    </section>

    <!-- MEDIA -->

    <section id="media">
      <h2>Media</h2>

      <figure>
        <picture>
          <source srcset="https://via.placeholder.com/400x200" />
          <img
            src="https://via.placeholder.com/400x200"
            alt="Placeholder"
            width="400"
            height="200"
          />
        </picture>
        <figcaption>Figure caption</figcaption>
      </figure>

      <video controls width="320"></video>
      <audio controls></audio>

      <iframe title="Example iframe" src="about:blank" width="300" height="150"
      ></iframe>

      <canvas width="150" height="100"></canvas>

      <svg width="100" height="100" role="img" aria-label="Circle">
        <circle cx="50" cy="50" r="40"></circle>
      </svg>
    </section>

    <!-- FORMS -->

    <section id="forms">
      <h2>Forms</h2>

      <form>
        <fieldset>
          <legend>Text Inputs</legend>

          <label>
            Text
            <input type="text" placeholder="Enter text…" />
          </label>

          <label>
            Search
            <input type="search" placeholder="Search…" />
          </label>

          <label>
            Email
            <input type="email" placeholder="you@example.com" />
          </label>

          <label>
            URL
            <input type="url" placeholder="https://…" />
          </label>

          <label>
            Password
            <input type="password" placeholder="••••••••" />
          </label>

          <label>
            Textarea
            <textarea rows="3" placeholder="Write something…"></textarea>
          </label>
        </fieldset>

        <fieldset>
          <legend>Other Inputs</legend>

          <label>
            Number
            <input type="number" placeholder="0" />
          </label>

          <label>
            Range
            <input type="range" min="0" max="100" value="50" />
          </label>

          <label>
            Date
            <input type="date" />
          </label>

          <label>
            Color
            <input type="color" value="#cc7c5e" />
          </label>

          <label>
            Datalist
            <input list="options" placeholder="Type to search…" />
            <datalist id="options">
              <option value="Option 1"></option>
              <option value="Option 2"></option>
              <option value="Option 3"></option>
            </datalist>
          </label>

          <label>
            Select
            <select>
              <option value="" disabled selected>Choose…</option>
              <optgroup label="Group A">
                <option>Option A</option>
                <option>Option B</option>
              </optgroup>
              <optgroup label="Group B">
                <option>Option C</option>
              </optgroup>
            </select>
          </label>
        </fieldset>

        <fieldset>
          <legend>Choices</legend>

          <label><input type="checkbox" /> Unchecked</label>
          <label><input type="checkbox" checked /> Checked</label>
          <label><input type="checkbox" disabled /> Disabled</label>

          <label><input type="radio" name="r" /> Option A</label>
          <label><input type="radio" name="r" checked /> Option B</label>
          <label><input type="radio" name="r" disabled /> Disabled</label>
        </fieldset>

        <fieldset>
          <legend>States</legend>

          <label>
            Disabled
            <input type="text" disabled value="Cannot edit" />
          </label>

          <label>
            Read-only
            <input type="text" readonly value="Read only value" />
          </label>

          <output>Computed: 42</output>
        </fieldset>

        <button type="submit">Submit</button>
        <button type="reset">Reset</button>
      </form>
    </section>

    <!-- INTERACTIVE -->

    <section id="interactive">
      <h2>Interactive</h2>

      <details>
        <summary>Toggle details</summary>
        <p>
          This content is revealed when the details element is open. It can
          contain any block-level content.
        </p>
      </details>

      <details open>
        <summary>Open by default</summary>
        <p>This details element starts in the open state.</p>
      </details>

      <h3>Progress &amp; Meter</h3>
      <progress value="70" max="100">70%</progress>
      <meter min="0" max="100" low="25" high="75" optimum="80" value="60"
        >60</meter
      >

      <h3>Dialog</h3>
      <dialog open>Dialog (open)</dialog>

      <h3>Popover</h3>
      <button popovertarget="popover">Toggle Popover</button>
      <div id="popover" popover>Popover content</div>
    </section>

    <!-- MISC -->

    <section id="misc">
      <h2>Miscellaneous</h2>

      <aside>
        <p>
          This is an aside — supplementary content tangentially related to the
          surrounding material.
        </p>
      </aside>

      <p>
        Published <time datetime="2026-01-01">January 1, 2026</time>. Value: <data
          value="42">Forty-two</data
        >.
      </p>

      <template>
        <p>Template content (not rendered)</p>
      </template>
    </section>

    <footer>
      <p class="text-muted">End of markup test page.</p>

      <nav aria-label="Related pages">
        <p class="text-muted">See also:</p>
        <ul>
          <li>
            <a href="/ai-generated/notes">Notes</a> — the philosophy behind choosing
            these semantic elements
          </li>
        </ul>
      </nav>
    </footer>
  </article>
</Layout>
