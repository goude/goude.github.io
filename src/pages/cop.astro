---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="cop — cloud clipboard portal"
  description="View and update whatever cop -n last pushed."
  current="cop"
>
  <section>
    <h1>cop</h1>
    <p class="subtitle">Cloud clipboard portal</p>
  </section>

  <section>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js"
      defer></script>

    <div class="cop-container">
      <div class="cop-status" id="cop-status">
        Fetching from cloud clipboard…
      </div>

      <div class="cop-qr-wrapper">
        <canvas id="cop-qr-canvas"></canvas>
        <a
          id="cop-url-link"
          class="cop-url-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"></a>
      </div>

      <textarea
        id="cop-input"
        class="cop-input"
        maxlength="2048"
        placeholder="(no data yet)"></textarea>
      <div class="cop-charcount" id="cop-charcount">0 / 2048</div>

      <div class="cop-actions">
        <button type="button" class="cop-button" id="cop-copy-btn">
          copy
        </button>
        <button type="button" class="cop-button" id="cop-update-btn">
          update
        </button>
      </div>
    </div>

    <script is:inline src="/scripts/cop.js" defer></script>
  </section>
</Layout>

<style>
  .cop-container {
    margin-top: 1rem;
    max-width: 30rem;
    font-family: var(--font-sans);
  }

  .cop-status {
    font-family: var(--font-code);
    font-size: 0.9rem;
    margin: 0.5rem 0 1rem;
    opacity: 0.7;
  }

  .cop-qr-wrapper {
    margin-bottom: 0.75rem;
  }

  .cop-url-link {
    font-size: 0.9rem;
    word-break: break-all;
    margin-top: 0.5rem;
    display: inline-block;
  }

  .cop-qr-wrapper canvas {
    border: 1px solid var(--rule);
    display: block;
    margin-top: 0.5rem;
    width: 400px;
    height: 400px;
    max-width: 100%;
    max-height: 100%;
  }

  .cop-input {
    width: 100%;
    box-sizing: border-box;
    border-radius: 4px;
    border: 1px solid var(--rule);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-code);
    font-size: 0.9rem;
    min-height: 6rem;
    resize: vertical;
    margin-top: 1.5rem;
    background: var(--bg);
    color: var(--fg);
  }

  .cop-actions {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .cop-button {
    border: 1px solid var(--rule);
    background: var(--bg);
    color: var(--fg);
    padding: 0.25rem 0.8rem;
    font-size: 0.8rem;
    cursor: pointer;
    border-radius: 999px;
    transition: opacity 0.15s ease;
  }

  .cop-button:hover:enabled {
    opacity: 0.7;
  }

  .cop-button:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .cop-charcount {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    opacity: 0.6;
    text-align: right;
  }
</style>
